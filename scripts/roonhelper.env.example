# Example environment overrides for roon-uploader-api.service and roon-uploader-worker.service
# Copy to /etc/roonhelper/roonhelper.env and adjust paths.

MUSIC_ROOT=/srv/music
CONFIG_FILE=/opt/roonhelper/shared/config.yaml
DB_PATH=/opt/roonhelper/shared/storage/app.db
INCOMING_SUBDIR=Incoming
TEMP_SUBDIR=.roon_uploader_tmp
MAX_TASK_SIZE_BYTES=10737418240
MAX_CHUNK_BYTES=5242880
ALLOWLIST=flac,mp3,wav
CLEANUP_DAYS=30
MOUNT_VALIDATION_MODE=strict
